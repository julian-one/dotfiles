# Font configuration
# Programming font with ligatures
font-family = "Comic Code Ligatures"
# Comfortable reading size
font-size = 18

# Increase line spacing for better readability
adjust-cell-height = 20%

# Add padding around terminal content
window-padding-x = 20
window-padding-y = 20

# Copy selected text to system clipboard automatically
copy-on-select = clipboard

# Visual effects
# Blur background when transparent
background-blur-radius = 15
# Don't confirm when closing window
confirm-close-surface = false

# macOS specific settings
# Use Option key as Alt modifier
macos-option-as-alt = true
# Transparent titlebar
macos-titlebar-style = native
# Hide proxy icon in titlebar
macos-titlebar-proxy-icon = hidden
# Empty title for clean look
title = " "
# Remove ghost emoji from window
macos-icon = official
# Maximize window when opened
fullscreen = true
